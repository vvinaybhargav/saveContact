<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_recents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_light"
        app:elevation="0dp">

    <!-- Header Card (collapses on scroll) -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_dark"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        app:layout_scrollFlags="scroll|enterAlways">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Calls"
            android:textColor="@color/accent_indigo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.01" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Review your device call log. Initiate dials or log recruiter calls directly to the job tracker."
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.1" />
    </LinearLayout>

        <!-- Search Bar Container (pinned below the collapsing header) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:background="@color/bg_light">

            <!-- Clipboard Banner (shows auto-detected copied numbers) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_clipboard_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/accent_indigo"
                app:cardBackgroundColor="@color/primary_dark"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_clipboard_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📋 Copied: +1234567890"
                        android:textColor="@color/white_constant"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clipboard_paste_dial"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Dial"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/status_green"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="6dp"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clipboard_track"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Track"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/accent_indigo"
                        app:cornerRadius="8dp"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_search_recents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search recent calls..."
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/accent_indigo"
                app:hintTextColor="@color/accent_indigo"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search_recents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Container for List or Empty State -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- Call Log List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recents"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="4dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"/>

            <!-- Empty State / No Permissions View -->
            <LinearLayout
                android:id="@+id/empty_state_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_menu_call"
                    app:tint="@color/divider"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="No call log" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Recent Calls"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Either your call log is empty, or the required Call Logs permission has not been granted. Grant permissions in the Tracker tab to enable."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>
        </FrameLayout>

    <!-- Keypad Drawer (Floating Card View sliding up) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_dialer_drawer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/glass_stroke"
        app:cardBackgroundColor="@color/primary_dark"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Handle slider bar visual -->
            <View
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:background="@color/divider"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Dialer Display Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageButton
                    android:id="@+id/btn_dialer_contacts"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/accent_indigo"
                    android:contentDescription="Search contacts" />

                <TextView
                    android:id="@+id/tv_dialer_digits"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Dial or paste a number"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="start"
                    android:gravity="center" />

                <ImageButton
                    android:id="@+id/btn_dialer_backspace"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_delete"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Backspace" />
            </LinearLayout>

            <!-- Keyboard Layout (Linear rows) -->
            <!-- Row 1: 1, 2, 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView android:id="@+id/key_1" style="@style/KeypadButtonStyle" android:text="1" />
                <TextView android:id="@+id/key_2" style="@style/KeypadButtonStyle" android:text="2" />
                <TextView android:id="@+id/key_3" style="@style/KeypadButtonStyle" android:text="3" />
            </LinearLayout>

            <!-- Row 2: 4, 5, 6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView android:id="@+id/key_4" style="@style/KeypadButtonStyle" android:text="4" />
                <TextView android:id="@+id/key_5" style="@style/KeypadButtonStyle" android:text="5" />
                <TextView android:id="@+id/key_6" style="@style/KeypadButtonStyle" android:text="6" />
            </LinearLayout>

            <!-- Row 3: 7, 8, 9 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView android:id="@+id/key_7" style="@style/KeypadButtonStyle" android:text="7" />
                <TextView android:id="@+id/key_8" style="@style/KeypadButtonStyle" android:text="8" />
                <TextView android:id="@+id/key_9" style="@style/KeypadButtonStyle" android:text="9" />
            </LinearLayout>

            <!-- Row 4: *, 0, # -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <TextView android:id="@+id/key_star" style="@style/KeypadButtonStyle" android:text="*" />
                <TextView android:id="@+id/key_0" style="@style/KeypadButtonStyle" android:text="0" />
                <TextView android:id="@+id/key_hash" style="@style/KeypadButtonStyle" android:text="#" />
            </LinearLayout>

            <!-- Dialer Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp">

                <!-- Cancel Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_dialer_close"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Cancel"
                    android:textColor="@color/text_secondary"
                    app:cornerRadius="16dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textStyle="bold"/>

                <!-- Dial Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_dialer_call"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/white"
                    android:maxLines="1"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/status_green"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_menu_call"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@color/white"/>

                <!-- Quick Track Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_dialer_track"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:textColor="@color/white"
                    android:maxLines="1"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/accent_indigo"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@color/white"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- FAB to slide up Keypad -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_show_dialer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_dialog_dialer"
        app:tint="@color/white"
        android:contentDescription="Open Dialpad"
        app:fabSize="normal"
        app:elevation="6dp"
        android:backgroundTint="@color/accent_indigo" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
