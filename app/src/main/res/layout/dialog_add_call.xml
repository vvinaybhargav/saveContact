<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="620dp"
    android:fillViewport="true"
    android:background="@color/bg_light">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <!-- Form Title -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_add_job_call"
        android:textColor="@color/text_primary"
        android:textSize="21sp"
        android:textStyle="bold"
        android:letterSpacing="0.01"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Every detail syncs to the call screen and timeline"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <!-- Phone Number Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_phone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:boxStrokeWidth="1.5dp"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_call"
        app:startIconTint="@color/accent_indigo">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_phone_number"
            android:inputType="phone"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- SECTION 1: CANDIDATE PROFILE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <View
            android:layout_width="3dp"
            android:layout_height="14dp"
            android:background="@color/accent_indigo"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANDIDATE PROFILE"
            android:textColor="@color/accent_indigo"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />
    </LinearLayout>

    <!-- Recruiter Name + Company side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_recruiter_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="@color/accent_indigo"
            app:hintTextColor="@color/accent_indigo">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_recruiter_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Recruiter"
                android:inputType="textPersonName"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_company"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="@color/accent_indigo"
            app:hintTextColor="@color/accent_indigo">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_company"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_company_name"
                android:inputType="textCapWords"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
        app:startIconTint="@color/text_muted">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_applied_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Applied Role / Skills"
            android:inputType="textCapWords"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- SECTION 2: INTERVIEW STATUS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <View
            android:layout_width="3dp"
            android:layout_height="14dp"
            android:background="@color/accent_indigo"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INTERVIEW STATUS"
            android:textColor="@color/accent_indigo"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/spinner_border">
        <Spinner
            android:id="@+id/spinner_round"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp"
            android:spinnerMode="dropdown" />
    </FrameLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
        app:startIconTint="@color/text_muted">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_tentative_schedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Next Call (tap to pick date &amp; time)"
            android:inputType="none"
            android:focusable="false"
            android:clickable="true"
            android:textColor="@color/text_primary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Numbered call history (1st Call, 2nd Call, ...) — same layout as the caller-ID
         banner. Only visible/populated for existing entries. -->
    <TextView
        android:id="@+id/label_notes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Call History"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="4dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/ll_notes_timeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp" />

    <!-- SECTION 3: NOTES (manual entry / recording upload) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <View
            android:layout_width="3dp"
            android:layout_height="14dp"
            android:background="@color/accent_indigo"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOTES"
            android:textColor="@color/accent_indigo"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_notes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_edit"
        app:startIconTint="@color/text_muted"
        app:endIconMode="custom"
        app:endIconDrawable="@drawable/ic_mic"
        app:endIconTint="@color/accent_indigo">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Add a note manually…"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="6"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tv_dialog_manual_recording"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginBottom="14dp"
        android:paddingVertical="4dp"
        android:text="📁 Upload a recording to transcribe ›"
        android:textColor="@color/accent_indigo"
        android:textSize="12sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground" />

    <!-- Dialog Transcription Progress -->
    <LinearLayout
        android:id="@+id/ll_dialog_transcription_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/pb_dialog_transcribe"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_dialog_transcription_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Transcribing call recording..."
            android:textColor="@color/accent_indigo"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Actions Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|end">

        <!-- Delete (Only for edits) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_delete"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/btn_delete"
            android:textAllCaps="false"
            android:textColor="@color/status_error"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone" />

        <!-- Save to Phone Contacts (Only for edits) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_save_contacts"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Save to Contacts"
            android:textAllCaps="false"
            android:textColor="@color/accent_indigo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone" />

        <!-- Schedule Follow-up Reminder (Only for edits) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_reminder"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Schedule Follow-up"
            android:textAllCaps="false"
            android:textColor="@color/accent_indigo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone" />

        <!-- Spacer View to push cancel and save to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Cancel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/btn_cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginEnd="8dp" />

        <!-- Submit -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_save"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/btn_add"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/accent_indigo"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>
</ScrollView>
