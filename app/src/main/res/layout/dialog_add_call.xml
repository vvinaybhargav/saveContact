<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="560dp"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Form Title -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_add_job_call"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Phone Number Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_phone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_call"
        app:startIconTint="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_phone_number"
            android:inputType="phone"
            android:textColor="@color/text_primary" />
    <!-- Recruiter Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_recruiter_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
        app:startIconTint="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_recruiter_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Recruiter Name"
            android:inputType="textPersonName"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Company Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_company"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
        app:startIconTint="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_company"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_company_name"
            android:inputType="textCapWords"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Tags Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_compass"
        app:startIconTint="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_tags"
            android:inputType="textCapWords"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Timeline: merged calls + dated notes, populated for existing entries -->
    <TextView
        android:id="@+id/label_notes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Call history &amp; notes"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="4dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/ll_notes_timeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_notes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/accent_indigo"
        app:hintTextColor="@color/accent_indigo"
        app:startIconDrawable="@android:drawable/ic_menu_edit"
        app:startIconTint="@color/text_muted"
        app:endIconMode="custom"
        app:endIconDrawable="@drawable/ic_mic"
        app:endIconTint="@color/accent_indigo">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Add a note…"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Dropdown Selection Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_select_round"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="4dp" />

    <!-- Custom outline wrapper for Spinner -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/spinner_border">

        <Spinner
            android:id="@+id/spinner_round"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp"
            android:spinnerMode="dropdown" />
    </FrameLayout>

    <!-- Actions Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Delete (Only for edits) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_delete"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/btn_delete"
            android:textAllCaps="false"
            android:textColor="@color/status_error"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone" />

        <!-- Save to Phone Contacts (Only for edits) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_save_contacts"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Save to Contacts"
            android:textAllCaps="false"
            android:textColor="@color/accent_indigo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone" />

        <!-- Schedule Follow-up Reminder (Only for edits) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_reminder"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Schedule Follow-up"
            android:textAllCaps="false"
            android:textColor="@color/accent_indigo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:visibility="gone" />

        <!-- Spacer View to push cancel and save to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Cancel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/btn_cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginEnd="8dp" />

        <!-- Submit -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_save"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/btn_add"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/accent_indigo"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>
</ScrollView>
