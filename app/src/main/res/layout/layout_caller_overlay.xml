<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_overlay_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/accent_indigo"
        app:cardBackgroundColor="@color/primary_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Header Row (Avatar, Details, Close button) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Circular Avatar -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_overlay_avatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/accent_indigo"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:id="@+id/tv_overlay_avatar_letter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="R"
                        android:textColor="@color/white_constant"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Name and Status Details -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_overlay_caller_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recruiter @ Company"
                        android:textColor="@color/white_constant"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_overlay_caller_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Stage: Screening · Android"
                        android:textColor="@color/accent_indigo"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Dismiss Button -->
                <!-- Edit Button -->
                <ImageView
                    android:id="@+id/btn_overlay_edit"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/text_muted"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Edit"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Dismiss Button -->
                <ImageView
                    android:id="@+id/btn_overlay_close"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/text_muted"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Dismiss"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="12dp" />

            <!-- Timeline Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <!-- Pointwise Notes Timeline -->
            <TextView
                android:id="@+id/tv_overlay_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.2"
                android:maxLines="3"
                android:ellipsize="end" />

            <!-- Talking Points (Highlights) Section -->
            <LinearLayout
                android:id="@+id/ll_overlay_highlights_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 TALKING POINTS"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_overlay_highlights"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Key highlights to mention..."
                    android:textColor="@color/accent_indigo"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Collapsible Note-Taking Edit Panel -->
            <LinearLayout
                android:id="@+id/ll_overlay_edit_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_overlay_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/accent_indigo"
                    app:hintTextColor="@color/accent_indigo"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="@color/text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_note_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Notes…"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:background="@drawable/spinner_border">

                        <Spinner
                            android:id="@+id/spinner_overlay_round"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:spinnerMode="dropdown" />
                    </FrameLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_overlay_cancel_note"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Cancel"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_overlay_save_note"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/accent_indigo"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
