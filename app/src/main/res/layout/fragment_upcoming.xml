<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_light"
        app:elevation="0dp">

        <!-- Header Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary_dark"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp"
            app:layout_scrollFlags="scroll|enterAlways">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Upcoming Interviews"
                android:textColor="@color/accent_indigo"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Manage your scheduled and tentative interviews. Tap any card to update rounds, details, or calendar follow-ups."
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.1" />
        </LinearLayout>

        <!-- Horizontally Scrollable Stage Filter Chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:background="@color/bg_light">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_upcoming_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">

                    <TextView android:id="@+id/chip_upcoming_all" android:text="All" style="@style/TrackerChipStyle" android:tag="selected" />
                    <TextView android:id="@+id/chip_upcoming_screening" android:text="Screening" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_upcoming_1st" android:text="1st Round" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_upcoming_2nd" android:text="2nd Round" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_upcoming_final" android:text="Final Round" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_upcoming_hr" android:text="HR / Salary" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_upcoming_needs_update" android:text="Needs Update" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_upcoming_scheduled" android:text="Scheduled" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_upcoming_no_followup" android:text="No Follow-up Needed" style="@style/TrackerChipStyle" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Sort by First Call / Recent Call -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/chip_sort_first_call"
                    android:text="Sort: First Call"
                    style="@style/TrackerChipStyle"
                    android:tag="selected" />
                <TextView
                    android:id="@+id/chip_sort_recent_call"
                    android:text="Sort: Recent Call"
                    style="@style/TrackerChipStyle" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Upcoming List Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_upcoming_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

        <!-- Empty State Stack -->
        <LinearLayout
            android:id="@+id/upcoming_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="48sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No interviews scheduled"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Any lead placed in interview/screening stages will appear here."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
