<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_light"
        app:elevation="0dp">

        <!-- Header Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary_dark"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp"
            app:layout_scrollFlags="scroll|enterAlways">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Interviews"
                android:textColor="@color/accent_indigo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Manage scheduled and tentative interviews."
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Filter dropdown spinner instead of horizontal chips and sort options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:background="@color/bg_light">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/spinner_border"
                android:paddingHorizontal="4dp">
                <Spinner
                    android:id="@+id/spinner_upcoming_filter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:spinnerMode="dropdown" />
            </FrameLayout>

            <!-- Dynamic Date Tabs -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout_upcoming_dates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:tabMode="scrollable"
                app:tabGravity="fill"
                app:tabSelectedTextColor="@color/accent_indigo"
                app:tabIndicatorColor="@color/accent_indigo"
                app:tabTextColor="@color/text_secondary"
                android:background="@color/bg_light" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Upcoming List Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_upcoming_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

        <!-- Empty State Stack -->
        <LinearLayout
            android:id="@+id/upcoming_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="48sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No interviews scheduled"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Any lead placed in interview/screening stages will appear here."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
