<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <!-- Header: Avatar, Caller Name, Status, Call Timer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="36dp"
        android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_overlay_avatar"
            android:layout_width="88dp"
            android:layout_height="88dp"
            app:cardCornerRadius="44dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/accent_indigo"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_overlay_avatar_letter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="R"
                android:textColor="@color/white_constant"
                android:textSize="34sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_overlay_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recruiter @ Company"
            android:textColor="@color/white_constant"
            android:textSize="21sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:gravity="center"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_overlay_caller_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Stage: First time · Android"
            android:textColor="@color/accent_indigo"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_call_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ringing…"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Scrollable notes / skills-match / call-history / note-editor content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Timeline Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <!-- Default Notes Layout (collapsed view) -->
            <LinearLayout
                android:id="@+id/ll_overlay_collapsed_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_overlay_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|end"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/tv_overlay_expand_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expand Notes"
                        android:textColor="@color/accent_indigo"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Expanded Notes Layout -->
            <LinearLayout
                android:id="@+id/ll_overlay_expanded_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/ll_overlay_expanded_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|end"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/tv_overlay_collapse_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Collapse Notes"
                        android:textColor="@color/accent_indigo"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Recent Call Info Section -->
            <LinearLayout
                android:id="@+id/ll_overlay_recent_call_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 CALL HISTORY"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_overlay_recent_call"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="First call - -  |  Recent call - NA"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Skills Match Section -->
            <LinearLayout
                android:id="@+id/ll_overlay_skills_match_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 SKILLS MATCH"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Matching"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_overlay_skills_matching"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not Matching"
                    android:textColor="#E53935"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_overlay_skills_not_matching"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Collapsible Note-Taking Edit Panel -->
            <LinearLayout
                android:id="@+id/ll_overlay_edit_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_shortlisted"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="Shortlisted"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/primary_light" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_tmrw_interview"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="tmrw interview at 12 pm"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/primary_light" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_next_round"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="Next round scheduled"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/primary_light" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_salary"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Salary discussed"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/primary_light" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Text fields: Name, Company, Expected CTC -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/accent_indigo"
                    app:hintTextColor="@color/accent_indigo">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Name"
                        android:inputType="textPersonName"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/accent_indigo"
                    app:hintTextColor="@color/accent_indigo">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_company"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Company"
                        android:inputType="text"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/accent_indigo"
                    app:hintTextColor="@color/accent_indigo">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_expected_ctc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Expected CTC"
                        android:inputType="text"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_overlay_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/accent_indigo"
                    app:hintTextColor="@color/accent_indigo"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="@color/text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_note_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Note of the call"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Dropdowns: Interview Round, Work Mode, Employment Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interview Round"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/spinner_border">
                    <Spinner
                        android:id="@+id/spinner_overlay_round"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="12dp"
                        android:spinnerMode="dropdown" />
                </FrameLayout>

                <!-- Next Call: tap to pick date/time, with a clear (✕) button -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next Call"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_overlay_next_call"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/accent_indigo"
                    app:hintTextColor="@color/accent_indigo"
                    app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                    app:startIconTint="@color/text_muted"
                    app:endIconMode="custom"
                    app:endIconDrawable="@android:drawable/ic_menu_close_clear_cancel"
                    app:endIconContentDescription="Clear next call"
                    app:endIconTint="@color/text_muted">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_next_call"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Next Call (optional)"
                        android:inputType="none"
                        android:focusable="false"
                        android:clickable="true"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hybrid / Onsite / Remote"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@drawable/spinner_border">
                            <Spinner
                                android:id="@+id/spinner_overlay_work_mode"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="12dp"
                                android:spinnerMode="dropdown" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="C2H / Direct Payroll"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@drawable/spinner_border">
                            <Spinner
                                android:id="@+id/spinner_overlay_employment_type"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="12dp"
                                android:spinnerMode="dropdown" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_overlay_cancel_note"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Cancel"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_overlay_save_note"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/accent_indigo"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Incoming-call controls: Decline / Answer -->
    <LinearLayout
        android:id="@+id/ll_incoming_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="22dp"
        android:visibility="gone">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_decline_call"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/white_constant"
            app:backgroundTint="#E53935"
            app:fabSize="normal"
            android:contentDescription="Decline" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_answer_call"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="28dp"
            android:src="@android:drawable/sym_action_call"
            app:tint="@color/white_constant"
            app:backgroundTint="#4CAF50"
            app:fabSize="normal"
            android:contentDescription="Answer" />
    </LinearLayout>

    <!-- Active-call controls: Mute / Add Note / Speaker / End -->
    <LinearLayout
        android:id="@+id/ll_active_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="18dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/btn_toggle_mute"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="14dp"
                android:src="@android:drawable/ic_lock_silent_mode"
                app:tint="@color/white_constant"
                android:background="@drawable/spinner_border"
                android:contentDescription="Mute" />
            <TextView
                android:id="@+id/tv_mute_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mute"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/btn_toggle_note"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="14dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/white_constant"
                android:background="@drawable/spinner_border"
                android:contentDescription="Add note" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Note"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/btn_toggle_speaker"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="14dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                app:tint="@color/white_constant"
                android:background="@drawable/spinner_border"
                android:contentDescription="Speaker" />
            <TextView
                android:id="@+id/tv_speaker_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Speaker"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_end_call"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white_constant"
                app:backgroundTint="#E53935"
                app:fabSize="mini"
                android:contentDescription="End call" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="End"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
