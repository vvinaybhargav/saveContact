<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_incall_gradient">

    <!-- Header: Avatar, Caller Name, Status, Call Timer -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Always-visible close button - a guaranteed way out of a review-mode log
             screen, independent of the Cancel/Save buttons further down. -->
        <ImageView
            android:id="@+id/btn_overlay_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="12dp"
            android:layout_marginTop="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/white_constant"
            android:background="@drawable/bg_glass_circle"
            android:visibility="gone"
            android:contentDescription="Close" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="44dp"
        android:paddingBottom="18dp">

        <FrameLayout
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_avatar_glow">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_overlay_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/accent_indigo">

                <TextView
                    android:id="@+id/tv_overlay_avatar_letter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="R"
                    android:textColor="@color/white_constant"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <TextView
            android:id="@+id/tv_overlay_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recruiter @ Company"
            android:textColor="@color/white_constant"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:maxLines="2"
            android:gravity="center"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_overlay_caller_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:background="@drawable/bg_glass_card"
            android:text="First time"
            android:textColor="#E8E8EA"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <HorizontalScrollView
            android:id="@+id/hsv_overlay_tags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/ll_overlay_tags_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tv_call_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Ringing…"
            android:textColor="#A0A0A5"
            android:textSize="14sp"
            android:letterSpacing="0.02" />
    </LinearLayout>
    </FrameLayout>

    <!-- Scrollable notes / skills-match / call-history / note-editor content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingHorizontal="18dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Notes glass card -->
            <LinearLayout
                android:id="@+id/ll_overlay_notes_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTES"
                    android:textColor="#ABABB0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <!-- Default Notes Layout (collapsed view) -->
                <LinearLayout
                    android:id="@+id/ll_overlay_collapsed_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_overlay_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#EDEDED"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.25" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical|end"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tv_overlay_expand_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expand ⌄"
                            android:textColor="@color/accent_glow"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Expanded Notes Layout -->
                <LinearLayout
                    android:id="@+id/ll_overlay_expanded_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/ll_overlay_expanded_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical|end"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tv_overlay_collapse_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Collapse ⌃"
                            android:textColor="@color/accent_glow"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Call history (shown inside expand) -->
                <LinearLayout
                    android:id="@+id/ll_overlay_recent_call_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/glass_stroke"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 CALL HISTORY"
                        android:textColor="#ABABB0"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_overlay_recent_call"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="First call - -  |  Recent call - NA"
                        android:textColor="#C7C7CC"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Skills Match glass card -->
            <LinearLayout
                android:id="@+id/ll_overlay_skills_match_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 SKILLS MATCH"
                    android:textColor="#ABABB0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Matching"
                    android:textColor="#4ADE80"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_overlay_skills_matching"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="#EDEDED"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not Matching"
                    android:textColor="#FB7185"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_overlay_skills_not_matching"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="#EDEDED"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- In-call DTMF dial pad (glass) -->
            <LinearLayout
                android:id="@+id/ll_overlay_dialpad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_overlay_dialpad_digits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text=""
                    android:textColor="@color/white_constant"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="start" />

                <LinearLayout
                    android:id="@+id/ll_overlay_dialpad_grid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tv_overlay_dialpad_close"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="8dp"
                    android:text="Close"
                    android:textColor="@color/accent_glow"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Structured note-capture panel (glass) -->
            <LinearLayout
                android:id="@+id/ll_overlay_edit_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD DETAILS"
                    android:textColor="#ABABB0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <!-- Quick preset chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_role"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="GCP Data Engineer"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/glass_fill_strong"
                            app:chipStrokeColor="@color/glass_stroke"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_hybrid"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="Hybrid"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/glass_fill_strong"
                            app:chipStrokeColor="@color/glass_stroke"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_c2h"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="C2H"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/glass_fill_strong"
                            app:chipStrokeColor="@color/glass_stroke"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_fulltime"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="Full Time"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/glass_fill_strong"
                            app:chipStrokeColor="@color/glass_stroke"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_interested"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="Interested"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/glass_fill_strong"
                            app:chipStrokeColor="@color/glass_stroke"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_interview_scheduled"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="Interview Scheduled"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/glass_fill_strong"
                            app:chipStrokeColor="@color/glass_stroke"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_preset_round_cleared"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Round Cleared"
                            android:textColor="@color/white_constant"
                            app:chipBackgroundColor="@color/glass_fill_strong"
                            app:chipStrokeColor="@color/glass_stroke"
                            app:chipStrokeWidth="1dp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <EditText
                    android:id="@+id/et_overlay_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_glass_field"
                    android:paddingHorizontal="14dp"
                    android:hint="Name"
                    android:textColorHint="#8E8E93"
                    android:inputType="textPersonName"
                    android:textColor="@color/white_constant"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_overlay_company"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_glass_field"
                    android:paddingHorizontal="14dp"
                    android:hint="Company"
                    android:textColorHint="#8E8E93"
                    android:inputType="text"
                    android:textColor="@color/white_constant"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_overlay_expected_ctc"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_glass_field"
                    android:paddingHorizontal="14dp"
                    android:hint="Expected CTC"
                    android:textColorHint="#8E8E93"
                    android:inputType="text"
                    android:textColor="@color/white_constant"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_overlay_note_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_glass_field"
                    android:padding="14dp"
                    android:gravity="top"
                    android:hint="Note of the call"
                    android:textColorHint="#8E8E93"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="2"
                    android:textColor="@color/white_constant"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interview Round"
                    android:textColor="#9C9CA3"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_glass_field">
                    <Spinner
                        android:id="@+id/spinner_overlay_round"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="10dp"
                        android:spinnerMode="dropdown" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next Call"
                    android:textColor="#9C9CA3"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_overlay_next_call"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="@color/glass_fill"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="@color/glass_stroke"
                    app:hintTextColor="#9C9CA3"
                    app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                    app:startIconTint="#9C9CA3"
                    app:endIconMode="custom"
                    app:endIconDrawable="@android:drawable/ic_menu_close_clear_cancel"
                    app:endIconContentDescription="Clear next call"
                    app:endIconTint="#9C9CA3">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_next_call"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Next Call (optional)"
                        android:inputType="none"
                        android:focusable="false"
                        android:clickable="true"
                        android:textColor="@color/white_constant" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JD SCREENSHOTS"
                    android:textColor="#9C9CA3"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/ll_overlay_jd_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical|end">

                    <TextView
                        android:id="@+id/btn_overlay_cancel_note"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:text="Cancel"
                        android:textColor="#A0A0A5"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground"/>

                    <TextView
                        android:id="@+id/btn_overlay_save_note"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:paddingHorizontal="26dp"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@color/white_constant"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:background="@drawable/bg_pill_accent"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- DTMF keypad - send touch-tones mid-call (IVR menus etc). Hidden by default,
         toggled by the Keypad button in the active-controls row. Digit buttons are
         built programmatically in InCallActivity.bindDialpad() into ll_overlay_dialpad_grid. -->
    <LinearLayout
        android:id="@+id/ll_overlay_dialpad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="12dp"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_overlay_dialpad_digits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text=" "
            android:textColor="@color/white_constant"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/ll_overlay_dialpad_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_overlay_dialpad_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"
            android:padding="8dp"
            android:text="Hide keypad"
            android:textColor="@color/accent_glow"
            android:textStyle="bold"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Incoming-call controls: Decline / Answer -->
    <LinearLayout
        android:id="@+id/ll_incoming_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="26dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_decline_call"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white_constant"
                app:backgroundTint="@color/decline_red"
                app:fabCustomSize="68dp"
                app:maxImageSize="28dp"
                app:elevation="8dp"
                android:contentDescription="Decline" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Decline"
                android:textColor="#C7C7CC"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_answer_call"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:src="@android:drawable/sym_action_call"
                app:tint="@color/white_constant"
                app:backgroundTint="@color/answer_green"
                app:fabCustomSize="68dp"
                app:maxImageSize="28dp"
                app:elevation="8dp"
                android:contentDescription="Answer" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Answer"
                android:textColor="#C7C7CC"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Active-call controls: Mute / Speaker / Keypad on row 1, Note / End on row 2 -->
    <LinearLayout
        android:id="@+id/ll_active_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:paddingHorizontal="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:id="@+id/btn_toggle_mute"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:padding="16dp"
                    android:src="@android:drawable/ic_lock_silent_mode"
                    app:tint="@color/white_constant"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Mute" />
                <TextView
                    android:id="@+id/tv_mute_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Mute"
                    android:textColor="#C7C7CC"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:id="@+id/btn_toggle_speaker"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:padding="16dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    app:tint="@color/white_constant"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Speaker" />
                <TextView
                    android:id="@+id/tv_speaker_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Speaker"
                    android:textColor="#C7C7CC"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:id="@+id/btn_toggle_dialpad"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:padding="16dp"
                    android:src="@drawable/ic_dialpad"
                    app:tint="@color/white_constant"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Dial pad" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Keypad"
                    android:textColor="#C7C7CC"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/ll_toggle_note_column"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:id="@+id/btn_toggle_note"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:padding="16dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/white_constant"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Add note" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Note"
                    android:textColor="#C7C7CC"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btn_end_call"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/white_constant"
                    app:backgroundTint="@color/decline_red"
                    app:fabCustomSize="58dp"
                    app:maxImageSize="26dp"
                    app:elevation="6dp"
                    android:contentDescription="End call" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="End"
                    android:textColor="#C7C7CC"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
