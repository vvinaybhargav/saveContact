<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider"
    app:cardBackgroundColor="@color/glass_fill_strong">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Call Type Circular Icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_call_type_bg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/status_blue_bg">

            <ImageView
                android:id="@+id/img_call_type_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_call"
                app:tint="@color/status_blue"
                android:contentDescription="Call type" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Call Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_caller_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name or Number"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_call_type_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Incoming"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tv_call_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Today, 10:30 AM"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Actions (Dial and Log) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Dial Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_action_dial"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="19dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/status_green"
                app:cardBackgroundColor="@color/status_green_bg">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_call"
                    app:tint="@color/status_green"
                    android:contentDescription="Call" />
            </com.google.android.material.card.MaterialCardView>

            <!-- More actions (Message, Copy) - shown as a popup menu -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_action_more"
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:cardCornerRadius="19dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/text_secondary"
                app:cardBackgroundColor="@color/glass_fill">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⋮"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:contentDescription="More actions" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
