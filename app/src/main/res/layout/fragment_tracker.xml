<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_tracker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_light"
        app:elevation="0dp">

    <!-- Header Card (collapses on scroll) -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_dark"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        app:layout_scrollFlags="scroll|enterAlways">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_dashboard"
            android:textColor="@color/accent_indigo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.01" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/desc_dashboard"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.1" />
    </LinearLayout>

        <!-- Analytics Stats Dashboard Card (pinned below the collapsing header) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stats_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:baselineAligned="false">

                <!-- Leads Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_leads"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_indigo" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Leads"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Separator -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="@color/divider"
                    android:layout_gravity="center_vertical"/>

                <!-- Screenings Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_screenings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_blue" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Screening"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Separator -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="@color/divider"
                    android:layout_gravity="center_vertical"/>

                <!-- Interviews Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_interviews"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_purple" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Interview"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Separator -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="@color/divider"
                    android:layout_gravity="center_vertical"/>

                <!-- Offers Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_offers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_green" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offers"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tap-through to full analytics -->
        <TextView
            android:id="@+id/tv_view_analytics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:paddingVertical="4dp"
            android:text="View detailed analytics ›"
            android:textColor="@color/accent_indigo"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tv_view_recordings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="2dp"
            android:paddingVertical="4dp"
            android:text="Call recordings ›"
            android:textColor="@color/accent_indigo"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:id="@+id/tv_test_overlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="2dp"
            android:paddingVertical="4dp"
            android:text="Test overlay banner (3 sec delay) ›"
            android:textColor="@color/accent_indigo"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

        <!-- API Key Settings Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">
            
            <TextView
                android:id="@+id/tv_toggle_dashboard_key"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼ Settings: Deepgram API Key"
                android:textColor="@color/accent_indigo"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:layout_gravity="end"
                android:paddingVertical="4dp"
                android:background="?android:attr/selectableItemBackground" />
                
            <LinearLayout
                android:id="@+id/ll_dashboard_key_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Deepgram API Key"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxStrokeColor="@color/accent_indigo"
                    app:hintTextColor="@color/accent_indigo">
                    
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_dashboard_deepgram_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_dashboard_key"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:layout_marginStart="8dp"
                    app:cornerRadius="8dp"
                    android:backgroundTint="@color/accent_indigo"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Search Bar and Status Chips Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:background="@color/bg_light">

            <!-- Outlined Search Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search phone, company, tag or notes..."
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/accent_indigo"
                app:hintTextColor="@color/accent_indigo"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/text_muted"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Horizontally Scrollable Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_filter_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">

                    <TextView android:id="@+id/chip_all" android:text="All" style="@style/TrackerChipStyle" android:tag="selected" />
                    <TextView android:id="@+id/chip_screening" android:text="Screening" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_1st_round" android:text="1st Round" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_2nd_round" android:text="2nd Round" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_final" android:text="Final Round" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_hr" android:text="HR / Salary" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_offered" android:text="Offered" style="@style/TrackerChipStyle" />
                    <TextView android:id="@+id/chip_rejected" android:text="Rejected" style="@style/TrackerChipStyle" />
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- Missing Permissions Alert Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_permissions_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/status_warning"
            app:cardBackgroundColor="@color/status_warning_bg"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    app:tint="@color/status_warning"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Warning" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/banner_permissions_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/banner_permissions_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main List Container (Swaps between RecyclerView and Empty State Stack) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- Call Log List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_job_calls"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="4dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"/>

            <!-- Empty State View (Centered inside remaining space) -->
            <LinearLayout
                android:id="@+id/empty_state_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/divider"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="Empty list" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Job Calls Logged Yet"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Incoming unsaved recruiter calls will trigger logs automatically, or you can add calls manually using the button below."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>
        </FrameLayout>

    <!-- FAB to log a call manually -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_call"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:tint="@color/white"
        android:contentDescription="@string/title_add_job_call"
        app:fabSize="normal"
        app:elevation="6dp"
        android:backgroundTint="@color/accent_indigo" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
