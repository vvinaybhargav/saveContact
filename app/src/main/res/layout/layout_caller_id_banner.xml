<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="10dp"
    app:strokeWidth="1dp"
    app:strokeColor="#312E81"
    app:cardBackgroundColor="#1E1B4B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Logo avatar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#312E81"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_today"
                app:tint="#818CF8"
                android:contentDescription="Job Call Tracker Icon"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recruiter Info details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_caller_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recruiter Call"
                android:textColor="#F9FAFB"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_caller_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Stage: First time"
                android:textColor="#C7D2FE"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dismiss button -->
        <ImageView
            android:id="@+id/btn_close_banner"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#9CA3AF"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Dismiss"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
